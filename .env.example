# ══════════════════════════════════════════
# OWNTOWN PROFIT FARMER v25.0 — CONFIG
# ══════════════════════════════════════════

# ── WALLET (REQUIRED) ──────────────────
WALLET_PRIVATE_KEY=your_base58_private_key_here
WALLET_ADDRESS=your_wallet_address_here

# ── PLAYER ─────────────────────────────
PLAYER_ID=
PLAYER_NAME=Elaina

# ── FARMING SETTINGS ───────────────────
# Mining
MINING_ACTION_COUNT=15
MINING_INTERVAL_MS=3500
# Fishing
FISHING_ACTION_COUNT=5
FISHING_INTERVAL_MS=25000
FISHING_TIMEOUT_MS=35000
# Combat
COMBAT_ACTION_COUNT=5
COMBAT_INTERVAL_MS=3000
# PvP
PVP_ACTION_COUNT=3
PVP_INTERVAL_MS=5000
PVP_MIN_LEVEL=5
PVP_MIN_STAMINA=30

# ── ECONOMY ────────────────────────────
DAILY_EARN_CAP=5000
CARRY_CAP=56
UNDERCUT_PCT=0.08
FLIP_COOLDOWN_MS=60000
FLIP_MAX_COST=200
FLIP_MIN_PROFIT=50
HEAL_HP_THRESHOLD=40
LOW_HP_THRESHOLD=25

# ── MARKET AI ──────────────────────────
# Enable smart market AI (moving avg + volume analysis)
MARKET_AI_ENABLED=true
# Price history window for trend analysis
MARKET_HISTORY_WINDOW=50
# Min samples before making predictions
MARKET_MIN_SAMPLES=5
# Hold items if price trending up by this %
MARKET_HOLD_TREND_PCT=0.15
# EMA alpha for price smoothing (0-1, lower = smoother)
MARKET_EMA_ALPHA=0.15

# ── PRIORITY FARMING ──────────────────
# Auto-switch to most profitable activity
PRIORITY_FARMING_ENABLED=true
# Recalculate priority every N cycles
PRIORITY_RECALC_CYCLES=4

# ── ANTI-DETECTION ─────────────────────
# Session length range (ms)
SESSION_MIN_MS=1200000
SESSION_MAX_MS=14400000
SESSION_MEAN_MS=5400000
# Break between sessions (ms)
BREAK_MIN_MS=300000
BREAK_MAX_MS=5400000
# Chance of very long break (sleep)
LONG_BREAK_CHANCE=0.10
# Social behavior (random chat, emote, profile check)
SOCIAL_BEHAVIOR_ENABLED=true
SOCIAL_ACTION_CHANCE=0.05
# Action skip chance (miss rate)
ACTION_SKIP_CHANCE=0.02
# Typing simulation in chat
CHAT_ENABLED=false
# Peak hours (UTC)
PEAK_HOUR_START=14
PEAK_HOUR_END=23
NIGHT_FLOOR_MULTIPLIER=0.25

# ── STATE PERSISTENCE ──────────────────
STATE_FILE=./state.json
STATE_SAVE_INTERVAL_MS=60000
# Resume from saved state on restart
STATE_RESUME=true

# ── NOTIFICATIONS ──────────────────────
# Telegram bot notifications
TELEGRAM_ENABLED=false
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=
# Webhook (Discord, etc)
WEBHOOK_ENABLED=false
WEBHOOK_URL=
# Notify intervals
NOTIFY_INTERVAL_MS=600000
# Alert on disconnect/error
NOTIFY_ON_ERROR=true
NOTIFY_ON_SESSION_BREAK=true

# ── SERVER ─────────────────────────────
SERVER_URL=https://owntown.fun
API_BASE=https://owntown.fun
WALLET_FILE=/root/.hermes/owntown-attack-wallet.json
TOKEN_FILE=./token.txt

# ── LOGGING ────────────────────────────
LOG_FILE=./bot.log
LOG_MAX_SIZE_MB=50
LOG_LEVEL=info
